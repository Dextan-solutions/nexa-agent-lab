# -----------------------------------------------------------------------------
# NexaBank Agent Security Lab — example environment (copy to .env)
#
# Section headers explain groups. Individual lines have no inline comments.
# Boolean and numeric values use the same names as backend Settings (Pydantic).
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Core platform
# -----------------------------------------------------------------------------
# Default difficulty band for vulnerable code paths at process start (LOW|MEDIUM|HARD|SECURE).
SECURITY_LEVEL=LOW

# -----------------------------------------------------------------------------
# LLM provider
# -----------------------------------------------------------------------------
# One of: ollama | openai | anthropic | gemini | mock
LLM_PROVIDER=ollama

# Seconds to wait for each upstream LLM HTTP call.
LLM_TIMEOUT_S=30

# -----------------------------------------------------------------------------
# Ollama (local)
# -----------------------------------------------------------------------------
# Empty string lets the backend probe host.docker.internal then the ollama service.
OLLAMA_BASE_URL=

OLLAMA_MODEL=qwen2.5:7b

OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

OPENAI_BASE_URL=https://api.openai.com/v1

OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Anthropic
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

ANTHROPIC_BASE_URL=https://api.anthropic.com

ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# -----------------------------------------------------------------------------
# Google Gemini
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

GEMINI_BASE_URL=https://generativelanguage.googleapis.com

GEMINI_MODEL=gemini-1.5-flash

# -----------------------------------------------------------------------------
# HTTP server (backend container)
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0

BACKEND_PORT=8000

# Base URL used when agent tools call NexaBank HTTP APIs from inside containers.
INTERNAL_API_BASE_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Auth / JWT (intentionally weak defaults for training)
# -----------------------------------------------------------------------------
JWT_SECRET=dev-insecure-secret

JWT_ISSUER=agenthive

JWT_AUDIENCE=nexabank

ACCESS_TOKEN_TTL_S=3600

# -----------------------------------------------------------------------------
# Rate limiting (Redis-backed)
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_S=60

RATE_LIMIT_REQUESTS_LOW=10000

RATE_LIMIT_REQUESTS_MEDIUM=600

RATE_LIMIT_REQUESTS_HARD=120

RATE_LIMIT_REQUESTS_SECURE=60

REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Persistence and audit
# -----------------------------------------------------------------------------
SQLITE_PATH=/data/agenthive.db

AUDIT_LOG_PATH=/data/audit.jsonl

# -----------------------------------------------------------------------------
# Vector database (Chroma)
# -----------------------------------------------------------------------------
CHROMA_HOST=chromadb

CHROMA_PORT=8000

# -----------------------------------------------------------------------------
# Frontend (Next.js build-time / runtime)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
